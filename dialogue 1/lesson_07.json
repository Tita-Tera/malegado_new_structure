              "value": "Is + [name] + a + [adjective] + [noun]?",
              "translatable": true
            },
            "concept_target": "[TRANSLATE]",
            "explanation_source": {
              "value": "In English, the adjective comes BEFORE the noun. So we say 'a big city', not 'a city big'. To ask a yes/no question, put 'Is' at the start: 'Is Pasadena a big city?'",
              "translatable": true
            },
            "explanation_target": "[TRANSLATE]",
            "focus_type": "variations",
