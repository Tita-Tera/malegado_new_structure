              "focus_type": "variations",
              "examples": [
                {
                  "example_id": "ex_04_001",
                  "text_source": "There has to be something on TV.",
                  "text_target": "[TRANSLATE]",
                  "register": "casual",
                  "usage_note_source": "'Has to be' is a common, conversational alternative to 'must be'.",
                  "usage_note_target": "[TRANSLATE]",
                  "audio_normal": "[GENERATE]",
                  "audio_slow": "[GENERATE]"
                },
                {
                  "example_id": "ex_04_002",
                  "text_source": "Surely there's something on TV.",
                  "text_target": "[TRANSLATE]",
                  "register": "neutral",
                  "usage_note_source": "Lead with 'surely' to soften the certainty into an expectation.",
                  "usage_note_target": "[TRANSLATE]",
                  "audio_normal": "[GENERATE]",
                  "audio_slow": "[GENERATE]"
                }
              ]
            }
          ],
