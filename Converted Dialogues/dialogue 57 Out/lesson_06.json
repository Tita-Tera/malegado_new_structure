          "grammar_points": [
            {
              "grammar_id": "gram_6",
              "concept_source": "'Have' with 'the' (specific) vs 'a' (any)",
              "concept_target": "[TRANSLATE]",
              "explanation_source": "Use 'I have' plus a noun to say you own something. Add 'the' before the noun when you are talking about a specific item both speakers know about. Use 'a' or 'an' when the item is just one of many. So 'I have the DVD' means that exact one — 'I have a DVD' just means you own one.",
              "explanation_target": "[TRANSLATE]",
              "focus_type": "variations",
              "examples": [
                {
                  "example_id": "ex_6_001",
                  "text_source": "I have a DVD.",
                  "text_target": "[TRANSLATE]",
                  "register": "neutral",
                  "usage_note_source": "Use 'a' when you mean any one DVD, not a specific copy.",
                  "usage_note_target": "[TRANSLATE]",
                  "audio_normal": "[GENERATE]",
                  "audio_slow": "[GENERATE]"
                },
                {
                  "example_id": "ex_6_002",
                  "text_source": "I have got the DVD.",
                  "text_target": "[TRANSLATE]",
                  "register": "informal",
                  "usage_note_source": "British speakers often use 'have got' instead of 'have'.",
                  "usage_note_target": "[TRANSLATE]",
                  "audio_normal": "[GENERATE]",
                  "audio_slow": "[GENERATE]"
                }
              ]
            }
          ],
          "grammar_engine_modifiers": [
            {
              "modifier_id": "mod_6_001",
              "modifier_source": "at home",
              "modifier_target": "[TRANSLATE]",
              "example_source": "I have the DVD at home.",
              "example_target": "[TRANSLATE]",
              "explanation_source": "Adds where the item is located.",
              "explanation_target": "[TRANSLATE]",
              "audio_normal": "[GENERATE]",
              "audio_slow": "[GENERATE]"
            },
            {
              "modifier_id": "mod_6_002",
