              "grammar_id": "gram_10",
              "concept_source": "Sequencing plans with 'Then' + simple present",
              "concept_target": "[TRANSLATE]",
              "explanation_source": "To put plans in order, use sequence words like 'first', 'then', 'next', and 'after that'. The verb often stays in the simple present even when the action is in the near future — say 'then we go' instead of 'then we will go'. This makes the plan sound clear and immediate.",
              "explanation_target": "[TRANSLATE]",
              "focus_type": "variations",
              "examples": [
                {
                  "example_id": "ex_10_001",
                  "text_source": "After that, we go to my home.",
                  "text_target": "[TRANSLATE]",
                  "register": "neutral",
                  "usage_note_source": "'After that' is a slightly fuller way to say 'then'.",
                  "usage_note_target": "[TRANSLATE]",
                  "audio_normal": "[GENERATE]",
                  "audio_slow": "[GENERATE]"
                },
                {
                  "example_id": "ex_10_002",
                  "text_source": "Then we will go to my home.",
                  "text_target": "[TRANSLATE]",
                  "register": "neutral",
                  "usage_note_source": "Adding 'will' makes the future a bit more explicit, but it is not required.",
                  "usage_note_target": "[TRANSLATE]",
                  "audio_normal": "[GENERATE]",
                  "audio_slow": "[GENERATE]"
                }
              ]
            }
          ],
