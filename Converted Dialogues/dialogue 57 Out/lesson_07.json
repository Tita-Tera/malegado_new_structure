              "concept_source": "Replacing nouns with the pronoun 'it'",
              "concept_target": "[TRANSLATE]",
              "explanation_source": "When you and a friend already know what you are talking about, replace the noun with the pronoun 'it'. So 'I have the DVD' becomes 'I have it'. Add 'too' at the end to echo your friend. The pronoun 'it' is for one thing — for more than one, use 'them'.",
              "explanation_target": "[TRANSLATE]",
              "focus_type": "variations",
              "examples": [
                {
                  "example_id": "ex_7_001",
                  "text_source": "I have it as well.",
                  "text_target": "[TRANSLATE]",
                  "register": "neutral",
                  "usage_note_source": "'As well' is a natural alternative to 'too' at the end.",
                  "usage_note_target": "[TRANSLATE]",
                  "audio_normal": "[GENERATE]",
                  "audio_slow": "[GENERATE]"
                },
                {
                  "example_id": "ex_7_002",
                  "text_source": "I own it too.",
                  "text_target": "[TRANSLATE]",
                  "register": "neutral",
                  "usage_note_source": "'Own' makes the sense of possession more explicit than 'have'.",
                  "usage_note_target": "[TRANSLATE]",
                  "audio_normal": "[GENERATE]",
                  "audio_slow": "[GENERATE]"
                }
              ]
            }
