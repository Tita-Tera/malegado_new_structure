              "concept_source": "Emotional reactions in the simple present",
              "concept_target": "[TRANSLATE]",
              "explanation_source": "To describe how a story makes you feel — every time you watch it — use the simple present. Say 'I cry', not 'I cried' or 'I am crying'. Add 'at the end' (or another time phrase) to anchor the reaction to a specific moment. The simple present here describes a habit, not just one occasion.",
              "explanation_target": "[TRANSLATE]",
              "focus_type": "variations",
              "examples": [
                {
                  "example_id": "ex_12_001",
                  "text_source": "It makes me sad at the end.",
                  "text_target": "[TRANSLATE]",
                  "register": "neutral",
                  "usage_note_source": "Variation that puts the feeling on the story rather than on yourself.",
                  "usage_note_target": "[TRANSLATE]",
                  "audio_normal": "[GENERATE]",
                  "audio_slow": "[GENERATE]"
                },
                {
                  "example_id": "ex_12_002",
                  "text_source": "I always cry at the end.",
                  "text_target": "[TRANSLATE]",
                  "register": "neutral",
                  "usage_note_source": "Adding 'always' makes the habit even clearer.",
                  "usage_note_target": "[TRANSLATE]",
                  "audio_normal": "[GENERATE]",
                  "audio_slow": "[GENERATE]"
                }
              ]
            }
