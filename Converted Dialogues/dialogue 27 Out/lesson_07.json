              "focus_type": "variations",
              "examples": [
                {
                  "example_id": "ex_7_001",
                  "text_source": "It is unknown what occurs after death.",
                  "text_target": "[TRANSLATE]",
                  "register": "formal",
                  "usage_note_source": "A more formal phrasing using the noun 'death' instead of the verb 'die'.",
                  "usage_note_target": "[TRANSLATE]",
                  "audio_normal": "[GENERATE]",
                  "audio_slow": "[GENERATE]"
                },
                {
                  "example_id": "ex_7_002",
                  "text_source": "Nobody really knows what happens after we die.",
                  "text_target": "[TRANSLATE]",
                  "register": "informal",
                  "usage_note_source": "In casual speech, swap 'No one' for 'Nobody' and add 'really' for emphasis.",
                  "usage_note_target": "[TRANSLATE]",
                  "audio_normal": "[GENERATE]",
                  "audio_slow": "[GENERATE]"
                }
              ]
            }
          ],
          "grammar_engine_modifiers": [
            {
              "modifier_id": "mod_7_001",
              "modifier_source": "really",
              "modifier_target": "[TRANSLATE]",
              "example_source": "No one really knows what happens after we die.",
              "example_target": "[TRANSLATE]",
              "explanation_source": "Add 'really' before the verb to emphasize the depth of the uncertainty.",
              "explanation_target": "[TRANSLATE]",
              "audio_normal": "[GENERATE]",
              "audio_slow": "[GENERATE]"
            },
