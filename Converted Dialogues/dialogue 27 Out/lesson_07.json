              "grammar_id": "gram_7",
              "concept_source": "time clauses with 'after'",
              "concept_target": "[TRANSLATE]",
              "explanation_source": "Use 'after' plus a subject and verb to show that one thing happens later than another: 'after we die', 'after they leave'. The whole 'after' group acts like a single time word.",
