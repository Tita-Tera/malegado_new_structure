              "grammar_id": "gram_11",
              "concept_source": "negative prefix 'un-'",
              "concept_target": "[TRANSLATE]",
              "explanation_source": "Add 'un-' to the start of many adjectives to make them mean the opposite: happy → unhappy, kind → unkind, lucky → unlucky. The same conditional pattern (if + present, will + verb) works with the new word.",
