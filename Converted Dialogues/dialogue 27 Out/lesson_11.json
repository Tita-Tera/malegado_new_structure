              "focus_type": "variations",
              "examples": [
                {
                  "example_id": "ex_11_001",
                  "text_source": "If we act badly, we will be miserable.",
                  "text_target": "[TRANSLATE]",
                  "register": "formal",
                  "usage_note_source": "A more formal phrasing using 'act badly' and 'miserable' instead of 'are bad' and 'unhappy'.",
                  "usage_note_target": "[TRANSLATE]",
                  "audio_normal": "[GENERATE]",
                  "audio_slow": "[GENERATE]"
                },
                {
                  "example_id": "ex_11_002",
                  "text_source": "If we're bad, we'll be sad.",
                  "text_target": "[TRANSLATE]",
                  "register": "informal",
                  "usage_note_source": "In casual speech, contractions and simpler 'sad' make the same idea feel everyday.",
                  "usage_note_target": "[TRANSLATE]",
                  "audio_normal": "[GENERATE]",
                  "audio_slow": "[GENERATE]"
                }
              ]
            }
          ],
          "grammar_engine_modifiers": [
            {
              "modifier_id": "mod_11_001",
              "modifier_source": "really",
              "modifier_target": "[TRANSLATE]",
              "example_source": "If we are really bad, we will be unhappy.",
              "example_target": "[TRANSLATE]",
              "explanation_source": "Add 'really' before the adjective to intensify the badness.",
              "explanation_target": "[TRANSLATE]",
              "audio_normal": "[GENERATE]",
              "audio_slow": "[GENERATE]"
            },
            {
              "modifier_id": "mod_11_002",
