              "grammar_id": "gram_10",
              "concept_source": "'many' + plural noun + plural verb",
              "concept_target": "[TRANSLATE]",
              "explanation_source": "Use 'many' before a plural noun like 'people'. Because the subject is plural, the verb has no -s ending: 'many people believe', not 'many people believes'. The word 'that' at the end refers back to an idea already mentioned.",
              "explanation_target": "[TRANSLATE]",
              "focus_type": "variations",
              "examples": [
                {
                  "example_id": "ex_10_001",
                  "text_source": "A great number of people hold that view.",
                  "text_target": "[TRANSLATE]",
                  "register": "formal",
                  "usage_note_source": "A formal phrasing using 'a great number of' instead of 'many' and 'hold that view' instead of 'believe that'.",
                  "usage_note_target": "[TRANSLATE]",
                  "audio_normal": "[GENERATE]",
                  "audio_slow": "[GENERATE]"
                },
                {
                  "example_id": "ex_10_002",
                  "text_source": "Lots of people think so.",
                  "text_target": "[TRANSLATE]",
                  "register": "informal",
                  "usage_note_source": "In casual speech, 'lots of' replaces 'many', and 'think so' replaces 'believe that'.",
                  "usage_note_target": "[TRANSLATE]",
                  "audio_normal": "[GENERATE]",
                  "audio_slow": "[GENERATE]"
                }
              ]
            }
          ],
          "grammar_engine_modifiers": [
