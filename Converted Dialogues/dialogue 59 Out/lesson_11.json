                  "example_id": "ex_11_001",
                  "text_source": "Your neighbors won't be happy.",
                  "text_target": "[TRANSLATE]",
                  "register": "informal",
                  "usage_note_source": "'Won't' is the contraction of 'will not'. Same meaning, more casual.",
                  "usage_note_target": "[TRANSLATE]",
                  "audio_normal": "[GENERATE]",
                  "audio_slow": "[GENERATE]"
                },
                {
                  "example_id": "ex_11_002",
                  "text_source": "The neighbors will be upset.",
                  "text_target": "[TRANSLATE]",
