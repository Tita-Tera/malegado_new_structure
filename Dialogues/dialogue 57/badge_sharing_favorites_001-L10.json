            "concept_target": "[TRANSLATE]",
            "explanation_source": {
              "value": "To put plans in order, use sequence words like 'first', 'then', 'next', and 'after that'. The verb often stays in the simple present even when the action is in the near future — say 'then we go' instead of 'then we will go'. This makes the plan sound clear and immediate.",
              "translatable": true
            },
            "explanation_target": "[TRANSLATE]",
            "focus_type": "variations",
            "examples": [
              {
                "example_id": "ex_10_001",
                "source_text": {
                  "value": "After that, we go to my home.",
                  "translatable": true
                },
                "target_text": "[TRANSLATE]",
                "register": "neutral",
                "usage_note_source": {
                  "value": "'After that' is a slightly fuller way to say 'then'.",
                  "translatable": true
                },
                "usage_note_target": "[TRANSLATE]"
              },
              {
                "example_id": "ex_10_002",
                "source_text": {
                  "value": "Then we will go to my home.",
                  "translatable": true
                },
                "target_text": "[TRANSLATE]",
                "register": "neutral",
                "usage_note_source": {
                  "value": "Adding 'will' makes the future a bit more explicit, but it is not required.",
