            "concept_target": "[TRANSLATE]",
            "explanation_source": {
              "value": "When you and a friend already know what you are talking about, replace the noun with the pronoun 'it'. So 'I have the DVD' becomes 'I have it'. Add 'too' at the end to echo your friend. The pronoun 'it' is for one thing — for more than one, use 'them'.",
              "translatable": true
            },
            "explanation_target": "[TRANSLATE]",
            "focus_type": "variations",
            "examples": [
              {
                "example_id": "ex_7_001",
                "source_text": {
                  "value": "I have it as well.",
                  "translatable": true
                },
                "target_text": "[TRANSLATE]",
                "register": "neutral",
                "usage_note_source": {
                  "value": "'As well' is a natural alternative to 'too' at the end.",
                  "translatable": true
                },
                "usage_note_target": "[TRANSLATE]"
              },
              {
                "example_id": "ex_7_002",
                "source_text": {
                  "value": "I own it too.",
                  "translatable": true
                },
                "target_text": "[TRANSLATE]",
                "register": "neutral",
                "usage_note_source": {
                  "value": "'Own' makes the sense of possession more explicit than 'have'.",
