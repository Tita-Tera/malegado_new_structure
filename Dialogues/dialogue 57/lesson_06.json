          "pro_tip": {
            "tip_id": "gram_6",
            "concept_source": {
              "value": "'Have' with 'the' (specific) vs 'a' (any)",
              "translatable": true
            },
            "concept_target": "[TRANSLATE]",
            "explanation_source": {
              "value": "Use 'I have' plus a noun to say you own something. Add 'the' before the noun when you are talking about a specific item both speakers know about. Use 'a' or 'an' when the item is just one of many. So 'I have the DVD' means that exact one — 'I have a DVD' just means you own one.",
              "translatable": true
            },
            "explanation_target": "[TRANSLATE]",
            "focus_type": "variations",
            "examples": [
              {
                "example_id": "ex_6_001",
                "source_text": {
                  "value": "I have a DVD.",
                  "translatable": true
                },
                "target_text": "[TRANSLATE]",
                "register": "neutral",
                "usage_note_source": {
                  "value": "Use 'a' when you mean any one DVD, not a specific copy.",
                  "translatable": true
                },
                "usage_note_target": "[TRANSLATE]"
              },
              {
                "example_id": "ex_6_002",
                "source_text": {
                  "value": "I have got the DVD.",
                  "translatable": true
                },
                "target_text": "[TRANSLATE]",
                "register": "informal",
                "usage_note_source": {
                  "value": "British speakers often use 'have got' instead of 'have'.",
                  "translatable": true
                },
                "usage_note_target": "[TRANSLATE]"
              }
            ]
          },
          "modifiers": [
            {
              "modifier_id": "mod_6_001",
