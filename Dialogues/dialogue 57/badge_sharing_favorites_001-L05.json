            "concept_source": {
              "value": "Echoing experiences with 'too' at the end",
              "translatable": true
            },
            "concept_target": "[TRANSLATE]",
            "explanation_source": {
              "value": "To say you have done the same thing as someone, repeat the sentence and add 'too' at the end. 'Too' goes after the object. You can also use 'also' before the verb, or 'as well' at the end. All three mean roughly the same thing — 'too' and 'as well' are most natural in casual speech.",
              "translatable": true
            },
            "explanation_target": "[TRANSLATE]",
            "focus_type": "variations",
            "examples": [
              {
                "example_id": "ex_5_001",
                "source_text": {
                  "value": "I also saw it many times.",
                  "translatable": true
                },
                "target_text": "[TRANSLATE]",
                "register": "neutral",
                "usage_note_source": {
                  "value": "'Also' goes before the main verb — slightly more formal than 'too'.",
                  "translatable": true
                },
                "usage_note_target": "[TRANSLATE]"
              },
              {
                "example_id": "ex_5_002",
                "source_text": {
                  "value": "I saw it many times as well.",
                  "translatable": true
                },
                "target_text": "[TRANSLATE]",
                "register": "neutral",
                "usage_note_source": {
                  "value": "'As well' is interchangeable with 'too' at the end of a sentence.",
                  "translatable": true
