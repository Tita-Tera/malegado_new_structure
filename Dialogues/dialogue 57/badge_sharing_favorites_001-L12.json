            },
            "concept_target": "[TRANSLATE]",
            "explanation_source": {
              "value": "To describe how a story makes you feel — every time you watch it — use the simple present. Say 'I cry', not 'I cried' or 'I am crying'. Add 'at the end' (or another time phrase) to anchor the reaction to a specific moment. The simple present here describes a habit, not just one occasion.",
              "translatable": true
            },
            "explanation_target": "[TRANSLATE]",
            "focus_type": "variations",
            "examples": [
              {
                "example_id": "ex_12_001",
                "source_text": {
                  "value": "It makes me sad at the end.",
                  "translatable": true
                },
                "target_text": "[TRANSLATE]",
                "register": "neutral",
                "usage_note_source": {
                  "value": "Variation that puts the feeling on the story rather than on yourself.",
                  "translatable": true
                },
                "usage_note_target": "[TRANSLATE]"
              },
              {
                "example_id": "ex_12_002",
                "source_text": {
                  "value": "I always cry at the end.",
                  "translatable": true
                },
