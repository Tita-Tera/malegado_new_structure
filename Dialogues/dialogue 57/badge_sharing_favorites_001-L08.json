                  "value": "Let's go to your home.",
                  "translatable": true
                },
                "target_text": "[TRANSLATE]",
                "register": "informal",
                "usage_note_source": {
                  "value": "The contracted 'Let's' is far more common in everyday speech than 'Let us'.",
                  "translatable": true
                },
                "usage_note_target": "[TRANSLATE]"
