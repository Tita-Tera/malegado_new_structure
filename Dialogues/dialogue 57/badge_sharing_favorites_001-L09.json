            },
            "explanation_target": "[TRANSLATE]",
            "focus_type": "variations",
            "examples": [
              {
                "example_id": "ex_9_001",
                "source_text": {
                  "value": "We could watch my DVD.",
                  "translatable": true
                },
                "target_text": "[TRANSLATE]",
                "register": "neutral",
                "usage_note_source": {
                  "value": "'Could' is even softer than 'can' — it sounds like a polite option.",
                  "translatable": true
                },
                "usage_note_target": "[TRANSLATE]"
              },
              {
                "example_id": "ex_9_002",
