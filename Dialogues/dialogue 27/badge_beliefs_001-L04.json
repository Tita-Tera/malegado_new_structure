                  "value": "It is probable that they will.",
                  "translatable": true
                },
                "target_text": "[TRANSLATE]",
                "register": "formal",
                "usage_note_source": {
                  "value": "A formal alternative using 'probable' as an adjective with 'it is'.",
                  "translatable": true
                },
                "usage_note_target": "[TRANSLATE]"
              },
              {
                "example_id": "ex_4_002",
                "source_text": {
                  "value": "Yeah, they probably will.",
                  "translatable": true
                },
                "target_text": "[TRANSLATE]",
