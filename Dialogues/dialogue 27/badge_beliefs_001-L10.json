            "explanation_source": {
              "value": "Use 'many' before a plural noun like 'people'. Because the subject is plural, the verb has no -s ending: 'many people believe', not 'many people believes'. The word 'that' at the end refers back to an idea already mentioned.",
              "translatable": true
            },
            "explanation_target": "[TRANSLATE]",
            "focus_type": "variations",
