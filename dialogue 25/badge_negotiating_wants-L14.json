          "dialogue": [
            {
              "turn_id": "turn_001",
              "turn_number": 1,
              "speaker": "PARTNER",
              "text_source": {
                "value": "I want a bicycle.",
                "translatable": true
              },
              "practice_mode": "listen_and_repeat"
            },
            {
              "turn_id": "turn_002",
              "turn_number": 2,
              "speaker": "YOU",
              "text_source": {
                "value": "Let me think about it.",
                "translatable": true
              },
              "practice_mode": "speak_along"
            },
            {
              "turn_id": "turn_003",
              "turn_number": 3,
              "speaker": "PARTNER",
              "text_source": {
                "value": "Why do you need to think?",
                "translatable": true
              },
              "practice_mode": "listen_and_repeat"
            },
            {
              "turn_id": "turn_004",
              "turn_number": 4,
              "speaker": "YOU",
              "text_source": {
                "value": "A bicycle costs money.",
                "translatable": true
              },
              "practice_mode": "speak_along"
            },
            {
              "turn_id": "turn_005",
              "turn_number": 5,
              "speaker": "PARTNER",
              "text_source": {
                "value": "Some bicycles are cheap.",
                "translatable": true
              },
              "practice_mode": "listen_and_repeat"
            },
            {
              "turn_id": "turn_006",
              "turn_number": 6,
              "speaker": "YOU",
              "text_source": {
                "value": "But you also need safety gear.",
                "translatable": true
              },
              "practice_mode": "speak_along"
            },
            {
              "turn_id": "turn_007",
              "turn_number": 7,
              "speaker": "PARTNER",
              "text_source": {
                "value": "Why do I need that?",
                "translatable": true
              },
              "practice_mode": "listen_and_repeat"
            },
            {
              "turn_id": "turn_008",
              "turn_number": 8,
              "speaker": "YOU",
              "text_source": {
                "value": "So you do not get hurt.",
                "translatable": true
              },
              "practice_mode": "speak_along"
            },
            {
              "turn_id": "turn_009",
              "turn_number": 9,
              "speaker": "YOU",
              "text_source": {
                "value": "You need a helmet.",
                "translatable": true
              },
              "practice_mode": "speak_along"
            },
            {
              "turn_id": "turn_010",
              "turn_number": 10,
              "speaker": "PARTNER",
              "text_source": {
                "value": "I do not like helmets.",
                "translatable": true
              },
              "practice_mode": "listen_and_repeat"
            },
            {
              "turn_id": "turn_011",
              "turn_number": 11,
              "speaker": "YOU",
              "text_source": {
                "value": "You also need to maintain it.",
                "translatable": true
              },
              "practice_mode": "speak_along"
            },
            {
              "turn_id": "turn_012",
              "turn_number": 12,
              "speaker": "YOU",
              "text_source": {
                "value": "That costs money too.",
                "translatable": true
              },
              "practice_mode": "speak_along"
            },
            {
              "turn_id": "turn_013",
              "turn_number": 13,
              "speaker": "PARTNER",
              "text_source": {
                "value": "I will take care of it.",
                "translatable": true
              },
              "practice_mode": "listen_and_repeat"
            },
            {
              "turn_id": "turn_014",
              "turn_number": 14,
              "speaker": "YOU",
              "text_source": {
                "value": "We will see.",
                "translatable": true
              },
              "practice_mode": "speak_along"
            }
          ]
